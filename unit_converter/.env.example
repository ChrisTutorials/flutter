# Copy this file to .env and fill in your actual values
# Do NOT commit .env to version control

# Google Play Console Service Account JSON key path
# Example: GOOGLE_APPLICATION_CREDENTIALS=C:/Users/yourname/.keys/play-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Play Store upload key path used by Fastlane Appfile
# Example: GOOGLE_PLAY_JSON_KEY_FILE=C:/dev/flutter/unit_converter/android/fastlane/google-play-service-account.json
GOOGLE_PLAY_JSON_KEY_FILE=

# AdMob App ID for the unit-converter app (release format: ca-app-pub-XXXXXXXXXXXXXXXX~NNNNNNNNNN)
UNIT_CONVERTER_ADMOB_APP_ID=

# Optional: Override default API endpoints (if needed)
# CURRENCY_API_BASE_URL=https://api.frankfurter.dev/v1
# CURRENCY_API_FALLBACK_URL=https://api.exchangerate.host/v1

# Feature flags (optional)
# ENABLE_DEBUG_LOGS=true
# DISABLE_ADS=false