# Appfile for Fastlane
# This file contains app-specific configuration

def load_project_dotenv
	env_file = File.expand_path('../../.env', __dir__)
	return unless File.exist?(env_file)

	File.foreach(env_file) do |line|
		stripped = line.strip
		next if stripped.empty? || stripped.start_with?('#') || !stripped.include?('=')

		key, value = stripped.split('=', 2)
		next if key.nil? || value.nil?

		cleaned_value = value.strip
		if (cleaned_value.start_with?('"') && cleaned_value.end_with?('"')) ||
			 (cleaned_value.start_with?("'") && cleaned_value.end_with?("'"))
			cleaned_value = cleaned_value[1..-2]
		end

		ENV[key.strip] = cleaned_value
	end
end

load_project_dotenv

# The package name of your app
package_name(ENV['PACKAGE_NAME'] || 'com.unitconverter.unit_converter')

# For more information about the Appfile, see:
#     https://docs.fastlane.tools/advanced/#appfile

# Play Store Service Account Configuration
# To use Play Store upload functionality, you need to:
# 1. Create a service account in Google Play Console
# 2. Download the JSON key file
# 3. Store it securely (never commit to git!)
# 4. Set the json_key_file path below or use environment variable

# Option 1: Use a JSON key file (recommended for development)
json_key_file(ENV['GOOGLE_PLAY_JSON_KEY_FILE'] || 'fastlane/google-play-service-account.json')

# Option 2: Use environment variable (recommended for CI/CD)
# Set GOOGLE_PLAY_SERVICE_ACCOUNT_JSON environment variable with the JSON content

# For more information on setting up a service account:
# https://docs.fastlane.tools/actions/supply/#setup

# Note: For security reasons, do not commit the JSON key file to version control
